# Smart Transaction Stack — environment configuration (Spec §7.6)
# Copy to `.env` and fill in real values. NEVER commit `.env` or keypair files.
# Code reads ALL configuration from these variables — no value is ever hardcoded.

# --- Yellowstone gRPC streaming (Watcher) ---
# gRPC endpoint URL + auth token. From Alchemy or Helius (Solana Devnet app).
YELLOWSTONE_ENDPOINT=https://your-devnet-grpc-endpoint.example.com
YELLOWSTONE_TOKEN=your-yellowstone-token

# --- Standard Solana RPC (one-off calls: blockhash, tip accounts, balances, gap recovery) ---
# Devnet is fine for everything that is NOT an actual Jito bundle submission.
SOLANA_RPC_URL=https://api.devnet.solana.com

# --- Devnet keypair (free test SOL) — for non-Jito development/testing ---
DEVNET_KEYPAIR_PATH=./devnet-keypair.json

# --- Jito block engine (bundle submission) ---
# CONFIRMED MAINNET-ONLY (Spec §1.6.1). Pick a regional variant if desired:
# amsterdam / frankfurt / ny / tokyo / slc.
JITO_BLOCK_ENGINE_URL=https://mainnet.block-engine.jito.wtf/api/v1/bundles

# --- Mainnet keypair (SEPARATE from devnet) — funded with a small amount of REAL SOL ---
# Required only for the actual Jito bundle submission step (Spec §1.6.1).
MAINNET_KEYPAIR_PATH=./mainnet-keypair.json

# --- Anthropic API (Agent) ---
ANTHROPIC_API_KEY=sk-ant-your-key

# --- Optional tuning (sensible defaults applied if unset) ---
# Number of upcoming Jito-enabled leaders to look ahead for (Watcher).
LEADER_LOOKAHEAD=8
# How many slots past a bundle's target slot before the silence watchdog fires.
SILENCE_GRACE_SLOTS=8
# Jito block-engine region used purely for documentation/logging.
JITO_REGION=mainnet
# Path for the durable lifecycle log (JSONL).
LIFECYCLE_LOG_PATH=./logs/lifecycle.jsonl
