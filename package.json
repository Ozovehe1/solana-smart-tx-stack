{
  "name": "solana-smart-tx-stack",
  "version": "0.1.0",
  "description": "Smart Transaction Stack — submits Solana transactions as Jito bundles, watches their lifecycle via Yellowstone gRPC, classifies failures, and hands one operational decision to a Claude agent.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "start": "tsx src/index.ts",
    "fault-inject": "tsx scripts/faultInject.ts",
    "check:live": "tsx scripts/checkLive.ts",
    "check:jito-devnet": "tsx scripts/checkJitoDevnet.ts",
    "check:testnet-bundle": "tsx scripts/checkTestnetBundle.ts",
    "agent:evidence": "tsx scripts/agentEvidence.ts",
    "agent:diff": "tsx scripts/agentDifferentiation.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@solana/web3.js": "^1.95.4",
    "@triton-one/yellowstone-grpc": "^1.3.0",
    "bs58": "^6.0.0",
    "dotenv": "^16.4.5",
    "jito-ts": "^4.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.3"
  }
}
